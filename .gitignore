# Note: the lsiutil binary (plugins/hbaviewer/hbaviewer.x86_64) is committed, not
# ignored — build.sh only downloads it when missing, so releases don't depend on
# that upstream URL still being up.

# Third-party Chart.js UMD build — fetched by build.sh (Performance tab)
source/usr/local/emhttp/plugins/hbaviewer/chart.umd.min.js

# Built package — uploaded as a GitHub release asset, not committed
releases/

# Raw storcli captures from the box — contain real drive serials, SAS addresses,
# WWNs. Sanitized fixtures live under tests/fixtures/storcli/ instead.
/storcli/
